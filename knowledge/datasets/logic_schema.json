{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "Nova Logic Dataset Schema",
    "type": "array",
    "items": {
        "type": "object",
        "required": [
            "input",
            "thought",
            "output"
        ],
        "properties": {
            "input": {
                "type": "string",
                "description": "User prompt"
            },
            "thought": {
                "type": "string",
                "description": "Chain of thought/reasoning"
            },
            "output": {
                "type": "string",
                "description": "Final response"
            },
            "metadata": {
                "type": "object",
                "properties": {
                    "difficulty": {
                        "type": "string"
                    },
                    "tags": {
                        "type": "array",
                        "items": {
                            "type": "string"
                        }
                    },
                    "source": {
                        "type": "string"
                    }
                }
            }
        }
    }
}